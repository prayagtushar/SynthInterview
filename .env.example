# Application Environment
NODE_ENV=development
APP_URL=http://localhost:3000

# Auth — your Gmail address gets admin access
NEXT_PUBLIC_ADMIN_EMAIL=you@gmail.com
# Demo code for hackathon judges (shown in presentation)
NEXT_PUBLIC_DEMO_CODE=SYNTH2025

# Firebase configuration (client side)
# Get these from your Firebase project Console > Project Settings
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# API configuration (server side)
# These should match your Firebase project
FIREBASE_PROJECT_ID=interview-ai-prod
# JSON format - download from Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT_JSON={"type": "service_account"...}
GCS_BUCKET_NAME=interview-ai-assets
REDIS_URL=redis://localhost:6379

# ── AI & Gemini Configuration ──────────────────────────────────────────────────
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
