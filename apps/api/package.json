{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "uv venv .venv --recreate && uv pip install --python .venv/bin/python -r requirements.txt",
    "dev": "source .venv/bin/activate && uvicorn app.main:app --reload --port 8000",
    "build": "python3 -m compileall app",
    "lint": "python3 -m compileall app",
    "typecheck": "python3 -m py_compile app/main.py"
  }
}
