# Application Environment
APP_ENV=development

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000

# ── AI & Gemini Configuration ──────────────────────────────────────────────────
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-live-001

# ── Firebase Configuration ─────────────────────────────────────────────────────
# Get these from Firebase Console > Project Settings
FIREBASE_PROJECT_ID=interview-ai-prod
# Download service account JSON from Firebase Console > Project Settings > Service Accounts
# Paste the JSON content below (keep it on a single line or use proper escaping)
FIREBASE_SERVICE_ACCOUNT_JSON={"type": "service_account"...}

# ── Google Cloud Storage ───────────────────────────────────────────────────────
GCS_BUCKET_NAME=interview-ai-assets

# ── Redis Configuration ───────────────────────────────────────────────────────
# Default: redis://localhost:6379 (for local development)
# For Docker: redis://redis:6379
REDIS_URL=redis://localhost:6379

# ── CORS & Security ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (use http://localhost:3000 for dev)
ALLOWED_ORIGINS=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
MAX_CONCURRENT_SESSIONS=50

# ── App URL (used in invite emails, password reset) ───────────────────────────
APP_URL=http://localhost:3000

# ── Email / SMTP Configuration ────────────────────────────────────────────────
# Leave SMTP_HOST blank to disable email sending
# For Gmail: Use App Password (not your regular password) if 2FA is enabled
# App Password: Google Account > Security > 2-Step Verification > App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com