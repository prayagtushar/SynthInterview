{
  "name": "synth-interview",
  "private": true,
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,yml,yaml}\"",
    "setup": "bun install && cd apps/api && uv venv .venv && uv pip install --python .venv/bin/python -r requirements.txt",
    "install:web": "bun install",
    "install:api": "cd apps/api && uv venv .venv && uv pip install --python .venv/bin/python -r requirements.txt"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "turbo": "^2.8.12",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1"
  }
}
